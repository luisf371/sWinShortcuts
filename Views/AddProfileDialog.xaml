<Window x:Class="sWinShortcuts.Views.AddProfileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Profile"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="24" Width="420">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Profile Name" Margin="0,0,0,4"/>
            <TextBox x:Name="NameTextBox" MinWidth="300"/>
        </StackPanel>

        <StackPanel Grid.Row="4">
            <TextBlock Text="Executable (.exe)" Margin="0,0,0,4"/>
            <DockPanel>
                <TextBox x:Name="ExecutableTextBox" MinWidth="260"/>
                <Button Content="Browse" Margin="8,0,0,0" Padding="12,4" DockPanel.Dock="Right" Click="OnBrowseClick"/>
            </DockPanel>
        </StackPanel>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="80" Margin="0,0,8,0" IsCancel="True" Click="OnCancelClick"/>
            <Button Content="Add" Width="80" IsDefault="True" Click="OnAddClick"/>
        </StackPanel>
    </Grid>
</Window>
