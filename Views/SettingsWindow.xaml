<Window x:Class="sWinShortcuts.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:sWinShortcuts.Converters"
        xmlns:behaviors="clr-namespace:sWinShortcuts.Behaviors"
        Title="Settings" Width="380" Height="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundElevatedBrush}">
    <Window.Resources>
        <conv:KeyDisplayConverter x:Key="KeyDisplayConverter" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Vertical">
            <TextBlock Text="Startup"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"
                       Foreground="{DynamicResource ForegroundPrimaryBrush}"/>

            <CheckBox x:Name="StartWithWindowsCheck"
                      Content="Start with Windows"
                      IsChecked="{Binding StartWithWindows, Mode=TwoWay}"
                      IsEnabled="{Binding CanEditStartup}"
                      Margin="0,0,0,8"
                      Foreground="{DynamicResource ForegroundPrimaryBrush}"/>

            <CheckBox x:Name="StartAsAdminCheck"
                      Content="Start as administrator"
                      IsChecked="{Binding StartAsAdmin, Mode=TwoWay}"
                      IsEnabled="{Binding CanChooseAdmin}"
                      Margin="24,0,0,8"
                      Foreground="{DynamicResource ForegroundPrimaryBrush}"/>
            
            <Separator Margin="0,8,0,8" Background="{DynamicResource BorderBrush}"/>
            
            <TextBlock Text="Troubleshooting"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"
                       Foreground="{DynamicResource ForegroundPrimaryBrush}"/>

            <CheckBox Content="Enable Debug Logging"
                      IsChecked="{Binding EnableDebugLogging, Mode=TwoWay}"
                      Margin="0,0,0,8"
                      Foreground="{DynamicResource ForegroundPrimaryBrush}"/>

            <CheckBox Content="Hook-loss watchdog (auto-recover dead hooks)"
                      IsChecked="{Binding HookWatchdogEnabled, Mode=TwoWay}"
                      ToolTip="Detects Windows silently removing the input hooks and re-installs them. Disable only to rule it out while troubleshooting."
                      Margin="0,0,0,8"
                      Foreground="{DynamicResource ForegroundPrimaryBrush}"/>

            <Separator Margin="0,8,0,8" Background="{DynamicResource BorderBrush}"/>

            <TextBlock Text="Color"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"
                       Foreground="{DynamicResource ForegroundPrimaryBrush}"/>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="132"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="Preset toggle key" FontWeight="SemiBold"/>
                    <TextBlock Text="Switches the active profile between Primary and Secondary. Choose an unused key; it still reaches the active app."
                               Foreground="{DynamicResource ForegroundSecondaryBrush}"
                               FontSize="11"
                               TextWrapping="Wrap"/>
                </StackPanel>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding ColorToggleKeyOptions}"
                          SelectedItem="{Binding ColorToggleKey, Mode=TwoWay}"
                          behaviors:ComboBoxKeySelectionBehavior.EnableKeySelection="True"
                          VerticalAlignment="Center"
                          Width="132">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource KeyDisplayConverter}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>


            <TextBlock Text="Advanced"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"
                       Foreground="{DynamicResource ForegroundPrimaryBrush}"/>

            <CheckBox Content="Enable Advanced Mode"
                      IsChecked="{Binding AdvancedModeEnabled, Mode=TwoWay}"
                      ToolTip="Enables non-1:1 automation (Auto-Run, Anti-AFK, Hold-Breath, and un-suppressed key mappings). Off = only game-safe 1:1 remaps."
                      Margin="0,0,0,8"
                      Foreground="{DynamicResource ForegroundPrimaryBrush}"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Width="80" Margin="0,0,8,0" MinHeight="28" IsCancel="True">Cancel</Button>
            <Button Width="80" Margin="0" MinHeight="28" IsDefault="True" IsEnabled="{Binding CanSave}" Click="OnSaveClick">Save</Button>
        </StackPanel>
    </Grid>
</Window>
