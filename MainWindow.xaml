<Window x:Class="sWinShortcuts.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:sWinShortcuts.ViewModels"
        xmlns:conv="clr-namespace:sWinShortcuts.Converters"
        xmlns:behaviors="clr-namespace:sWinShortcuts.Behaviors"
        Title="sWinShortcuts"
        Icon="pack://application:,,,/Icons/Icon.ico"
        Width="1100"
        Height="720"
        MinWidth="960"
        MinHeight="640"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        x:Name="RootWindow"
        Closing="Window_Closing"
        SizeChanged="Window_SizeChanged"
        LocationChanged="Window_LocationChanged">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False"
                      NonClientFrameEdges="None" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <conv:BooleanNegationConverter x:Key="NotConverter" />
        <conv:KeyDisplayConverter x:Key="KeyDisplayConverter" />
        <conv:MouseButtonDisplayConverter x:Key="MouseButtonDisplayConverter" />
        <conv:InputTriggerDisplayConverter x:Key="InputTriggerDisplayConverter" />
        <conv:AvailableMouseButtonsConverter x:Key="AvailableMouseButtonsConverter" />
        <conv:AvailableKeysConverter x:Key="AvailableKeysConverter" />
        <conv:BooleanToVisibilityConverterEx x:Key="VisibleIfTrue" />
        <conv:BooleanToVisibilityConverterEx x:Key="VisibleIfFalse" Invert="True" />
        
        <Style x:Key="DisabledContentShadeStyle" TargetType="FrameworkElement">
            <Setter Property="Opacity" Value="1" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="FeatureToggleContentStyle" TargetType="FrameworkElement">
            <Setter Property="Opacity" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="False">
                    <Setter Property="Opacity" Value="0.75" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <!-- Custom Title Bar -->
        <Border Grid.Row="0"
                Background="{DynamicResource BackgroundElevatedBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                x:Name="TitleBar"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <TextBlock Text="sWinShortcuts"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="12,0,0,0"
                           Foreground="{DynamicResource ForegroundPrimaryBrush}"
                           FontSize="12" />
                <StackPanel Orientation="Horizontal"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Top">
                    <Button Click="SettingsButton_Click"
                            Style="{StaticResource TitleBarButtonStyle}"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            ToolTip="Settings"
                            ToolTipService.InitialShowDelay="0"
                            ToolTipService.Placement="Right"
                            Margin="0,0,4,0">
                        <TextBlock Text="&#xE713;" FontSize="12" FontFamily="Segoe MDL2 Assets" />
                    </Button>
                    <Button Click="CloseButton_Click"
                            Style="{StaticResource TitleBarCloseButtonStyle}"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            ToolTip="Minimize to tray"
                            ToolTipService.InitialShowDelay="0"
                            ToolTipService.Placement="Right">
                        <TextBlock Text="&#xE8BB;" FontSize="12" FontFamily="Segoe MDL2 Assets" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="8*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="16,8,16,16"
                Padding="16"
                Background="{DynamicResource BackgroundElevatedBrush}"
                CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ListBox Grid.Row="0"
                         ItemsSource="{Binding Profiles}"
                         SelectedItem="{Binding SelectedProfile}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{DynamicResource ForegroundPrimaryBrush}">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ProfileViewModel}">
                            <StackPanel Orientation="Horizontal" Margin="4">
                                <TextBlock Text="{Binding Name}" />
                                <TextBlock Text=" (disabled)" Margin="6,0,0,0" Foreground="{StaticResource ForegroundPrimaryBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                </ListBox>

                <Grid Grid.Row="1" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Add" Command="{Binding AddProfileCommand}" Margin="0,0,6,0" />
                    <Button Grid.Column="1" Content="Remove" Command="{Binding RemoveProfileCommand}" Margin="6,0,0,0" />
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Margin="16,8,16,16"
                Padding="0"
                Background="{DynamicResource BackgroundElevatedBrush}"
                CornerRadius="12"
                ClipToBounds="True">
            <ScrollViewer Margin="0"
                          Padding="24,16,28,24"
                          Background="Transparent"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Resources>
                    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#331E2A3B" />
                    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#88E1E1E1" />
                    <Style x:Key="MinimalScrollBarButtonStyle" TargetType="RepeatButton">
                        <Setter Property="Focusable" Value="False" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="RepeatButton">
                                    <Border Background="Transparent" />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <Style x:Key="MinimalScrollBarThumbStyle" TargetType="Thumb">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Thumb">
                                    <Border x:Name="ThumbRoot"
                                            Background="{StaticResource ScrollBarThumbBrush}"
                                            CornerRadius="4" />
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ThumbRoot"
                                                    Property="Background"
                                                    Value="{DynamicResource AccentBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsDragging" Value="True">
                                            <Setter TargetName="ThumbRoot"
                                                    Property="Background"
                                                    Value="{DynamicResource AccentDarkBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <Style TargetType="ScrollBar">
                        <Setter Property="Width" Value="8" />
                        <Setter Property="Background" Value="{StaticResource ScrollBarTrackBrush}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Grid x:Name="Root"
                                          Width="{TemplateBinding Width}"
                                          Background="Transparent">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4" />
                                        <Track x:Name="PART_Track"
                                               IsDirectionReversed="True"
                                               Margin="0">
                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton Command="ScrollBar.LineUpCommand"
                                                              Style="{StaticResource MinimalScrollBarButtonStyle}" />
                                            </Track.DecreaseRepeatButton>
                                            <Track.Thumb>
                                                <Thumb Style="{StaticResource MinimalScrollBarThumbStyle}" />
                                            </Track.Thumb>
                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton Command="ScrollBar.LineDownCommand"
                                                              Style="{StaticResource MinimalScrollBarButtonStyle}" />
                                            </Track.IncreaseRepeatButton>
                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Resources>
                <ScrollViewer.Template>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" />
                            <Border Margin="{TemplateBinding Padding}">
                                <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                        CanContentScroll="{TemplateBinding CanContentScroll}"
                                                        Content="{TemplateBinding Content}"
                                                        ContentTemplate="{TemplateBinding ContentTemplate}"
                                                        ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Border>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       HorizontalAlignment="Right"
                                       Margin="0,16,1,16"
                                       Orientation="Vertical"
                                       Minimum="0"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" />
                            <ScrollBar x:Name="PART_HorizontalScrollBar"
                                       VerticalAlignment="Bottom"
                                       Margin="16,0,16,16"
                                       Orientation="Horizontal"
                                       Minimum="0"
                                       Maximum="{TemplateBinding ScrollableWidth}"
                                       ViewportSize="{TemplateBinding ViewportWidth}"
                                       Value="{TemplateBinding HorizontalOffset}"
                                       Visibility="Collapsed" />
                        </Grid>
                    </ControlTemplate>
                </ScrollViewer.Template>
                <ContentControl Content="{Binding SelectedProfile}">
                                        <ContentControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:ProfileViewModel}">
                            <StackPanel Margin="0">
                                <CheckBox Margin="0,0,0,8"
                                          IsChecked="{Binding IsEnabled}"
                                          IsEnabled="{Binding CanToggleEnabled}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          VerticalContentAlignment="Center"
                                          Padding="5">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Margin="0,0,0,5"
                                               VerticalAlignment="Center" />
                                </CheckBox>

                                <StackPanel IsEnabled="{Binding CanEditContent}"
                                            Style="{StaticResource DisabledContentShadeStyle}">
                                    <StackPanel Visibility="{Binding IsColorProfile, Converter={StaticResource VisibleIfFalse}}">
                                        <StackPanel Margin="0,0,0,8"
                                                    Visibility="{Binding IsWindowsProfile, Converter={StaticResource VisibleIfFalse}}">
                                        <TextBlock Text="Executable" Margin="0,0,0,4" />
                                        <DockPanel>
                                            <Button Content="Modify"
                                                    Command="{Binding DataContext.ModifyProfileCommand, ElementName=RootWindow}"
                                                    DockPanel.Dock="Right"
                                                    Margin="8,0,0,0"
                                                    Width="100" />
                                            <!-- F-017: display-only. The inline PropertyChanged binding
                                                 let unvalidated (empty / non-.exe / duplicate) targets
                                                 persist straight to the model on every keystroke. All
                                                 executable edits now go through the validated Modify flow. -->
                                            <TextBox Text="{Binding Executable, Mode=OneWay}"
                                                     IsReadOnly="True"
                                                     ToolTip="Use Modify to change the target executable (validated)." />
                                        </DockPanel>
                                    </StackPanel>

                                    <!-- Combined Key Mappings (Global + Right-click) -->
                                    <GroupBox Padding="16" Margin="0,0,0,8"
                                              Visibility="{Binding IsWindowsProfile, Converter={StaticResource VisibleIfFalse}}">
                                        <GroupBox.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <CheckBox Content="Key Mappings"
                                                          IsChecked="{Binding CombinedKeyMappingsEnabled, Mode=TwoWay}"
                                                          Margin="0"
                                                          VerticalAlignment="Center" />
                                                <TextBlock Style="{StaticResource InfoIconStyle}"
                                                           ToolTip="Single list of mappings. Toggle Right-click column to apply only while holding right button. The toggle enables/disables both global and right-click mappings."
                                                           ToolTipService.InitialShowDelay="0"
                                                           ToolTipService.Placement="Right" />
                                            </StackPanel>
                                        </GroupBox.Header>
                                        <StackPanel Margin="0,8,0,0"
                                                    IsEnabled="{Binding CombinedKeyMappingsEnabled}"
                                                    Tag="{Binding CombinedKeyMappingsEnabled}"
                                                    Style="{StaticResource FeatureToggleContentStyle}">

                                            <DataGrid ItemsSource="{Binding CombinedMappings}"
                                                      SelectedItem="{Binding SelectedCombinedMapping, Mode=TwoWay}"
                                                      AutoGenerateColumns="False"
                                                      HeadersVisibility="Column"
                                                      CanUserAddRows="False"
                                                      CanUserReorderColumns="False"
                                                      CanUserResizeColumns="False"
                                                      CanUserDeleteRows="False"
                                                      Margin="0,0,0,8"
                                                      RowHeight="32"
                                                      BorderThickness="0">
                                                <DataGrid.Columns>
                                                    <DataGridTemplateColumn Header="Source" Width="*">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <ComboBox SelectedItem="{Binding SourceKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          ItemsSource="{Binding SelectableSourceKeys}"
                                                                          IsSynchronizedWithCurrentItem="False"
                                                                          behaviors:ComboBoxKeySelectionBehavior.EnableKeySelection="True">
                                                                    <ComboBox.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock Text="{Binding Converter={StaticResource KeyDisplayConverter}}" />
                                                                        </DataTemplate>
                                                                    </ComboBox.ItemTemplate>
                                                                </ComboBox>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="Target" Width="*">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <ComboBox ItemsSource="{Binding DataContext.KeyOptions, ElementName=RootWindow}"
                                                                          SelectedItem="{Binding TargetKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          IsSynchronizedWithCurrentItem="False"
                                                                          behaviors:ComboBoxKeySelectionBehavior.EnableKeySelection="True">
                                                                    <ComboBox.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock Text="{Binding Converter={StaticResource KeyDisplayConverter}}" />
                                                                        </DataTemplate>
                                                                    </ComboBox.ItemTemplate>
                                                                </ComboBox>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="Right-click" Width="Auto">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <CheckBox IsChecked="{Binding RightClickOnly, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          VerticalAlignment="Center"
                                                                          HorizontalAlignment="Center" />
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Width="Auto">
                                                        <DataGridTemplateColumn.Header>
                                                            <StackPanel Orientation="Horizontal"
                                                                        ToolTip="⚠️ WARNING: Turning Suppression Off violates '1 key = 1 action' rules in competitive or anti-cheat restricted games. Use at your own risk."
                                                                        ToolTipService.InitialShowDelay="0"
                                                                        ToolTipService.Placement="Right">
                                                                <TextBlock Text="Suppress" VerticalAlignment="Center" />
                                                                <TextBlock Style="{StaticResource WarningIconStyle}" Margin="4,0,0,0" />
                                                            </StackPanel>
                                                        </DataGridTemplateColumn.Header>
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <CheckBox IsChecked="{Binding SuppressOriginalKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          IsEnabled="{Binding DataContext.AdvancedModeEnabled, ElementName=RootWindow}"
                                                                          VerticalAlignment="Center"
                                                                          HorizontalAlignment="Center" />
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="🗑️" Width="Auto">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Button Content="✕"
                                                                        Command="{Binding DataContext.RemoveCombinedMappingCommand, ElementName=RootWindow}"
                                                                        CommandParameter="{Binding}"
                                                                        Width="30"
                                                                        Height="24"
                                                                        Padding="0"
                                                                        FontSize="14"
                                                                        ToolTip="Remove this mapping"
                                                                        ToolTipService.InitialShowDelay="0"
                                                                        ToolTipService.Placement="Right" />
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                </DataGrid.Columns>
                                            </DataGrid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0"
                                                        Content="Add Mapping"
                                                        Command="{Binding DataContext.AddCombinedMappingCommand, ElementName=RootWindow}"
                                                        Width="130"
                                                        Height="32" />
                                                <Button Grid.Column="1"
                                                        Content="Remove All Mappings"
                                                        Command="{Binding DataContext.RemoveAllCombinedMappingsCommand, ElementName=RootWindow}"
                                                        Width="170"
                                                        Margin="16,0,0,0"
                                                        Height="32"
                                                        HorizontalAlignment="Right" />
                                            </Grid>
                                        </StackPanel>
                                    </GroupBox>

                                    <GroupBox Padding="16" Margin="0,0,0,8"
                                              Visibility="{Binding IsWindowsProfile, Converter={StaticResource VisibleIfFalse}}">
                                        <GroupBox.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <CheckBox Content="Alt + Mouse"
                                                          IsChecked="{Binding AltMouse.IsEnabled}"
                                                          Margin="0"
                                                          VerticalAlignment="Center" />
                                                <TextBlock Style="{StaticResource InfoIconStyle}"
                                                           ToolTip="Hold Alt and click mouse buttons to trigger tap/hold actions. Configure button mappings and hold threshold below."
                                                           ToolTipService.InitialShowDelay="0"
                                                           ToolTipService.Placement="Right" />
                                            </StackPanel>
                                        </GroupBox.Header>
                                        <StackPanel Margin="0,8,0,0"
                                                    IsEnabled="{Binding AltMouse.IsEnabled}"
                                                    Tag="{Binding AltMouse.IsEnabled}"
                                                    Style="{StaticResource FeatureToggleContentStyle}">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="Hold threshold (ms)"
                                                           VerticalAlignment="Center"
                                                           Width="140" />
                                                <Slider Value="{Binding AltMouse.HoldThresholdMilliseconds, UpdateSourceTrigger=PropertyChanged}"
                                                        Minimum="10"
                                                        Maximum="1000"
                                                        TickFrequency="5"
                                                        IsSnapToTickEnabled="True"
                                                        Width="200"
                                                        VerticalAlignment="Center"
                                                        Margin="8,0,8,0" />
                                                <TextBlock Text="{Binding AltMouse.HoldThresholdMilliseconds, StringFormat='{}{0} ms'}"
                                                           VerticalAlignment="Center"
                                                           Width="50"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>

                                            <DataGrid ItemsSource="{Binding AltMouseBindings}"
                                                      AutoGenerateColumns="False"
                                                      HeadersVisibility="Column"
                                                      CanUserAddRows="False"
                                                      CanUserReorderColumns="False"
                                                      CanUserResizeColumns="False"
                                                      CanUserDeleteRows="False"
                                                      Margin="0,0,0,8"
                                                      RowHeight="32"
                                                      BorderThickness="0">
                                                <DataGrid.Columns>
                                                    <DataGridTemplateColumn Header="Button" Width="*">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <ComboBox SelectedItem="{Binding Button, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=100}"
                                                                          IsSynchronizedWithCurrentItem="False">
                                                                    <ComboBox.ItemsSource>
                                                                        <MultiBinding Converter="{StaticResource AvailableMouseButtonsConverter}" UpdateSourceTrigger="PropertyChanged">
                                                                            <Binding Path="DataContext.SelectedProfile.AvailableMouseButtons" ElementName="RootWindow" Mode="OneWay" />
                                                                            <Binding Path="Button" Mode="OneWay" />
                                                                        </MultiBinding>
                                                                    </ComboBox.ItemsSource>
                                                                    <ComboBox.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock Text="{Binding Converter={StaticResource MouseButtonDisplayConverter}}" />
                                                                        </DataTemplate>
                                                                    </ComboBox.ItemTemplate>
                                                                </ComboBox>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="Tap" Width="*">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <ComboBox ItemsSource="{Binding DataContext.KeyOptionsWithNone, ElementName=RootWindow}"
                                                                          SelectedItem="{Binding TapKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          behaviors:ComboBoxKeySelectionBehavior.EnableKeySelection="True">
                                                                    <ComboBox.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock Text="{Binding Converter={StaticResource KeyDisplayConverter}}" />
                                                                        </DataTemplate>
                                                                    </ComboBox.ItemTemplate>
                                                                </ComboBox>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="Hold" Width="*">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <ComboBox ItemsSource="{Binding DataContext.KeyOptionsWithNone, ElementName=RootWindow}"
                                                                          SelectedItem="{Binding HoldKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          behaviors:ComboBoxKeySelectionBehavior.EnableKeySelection="True">
                                                                    <ComboBox.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock Text="{Binding Converter={StaticResource KeyDisplayConverter}}" />
                                                                        </DataTemplate>
                                                                    </ComboBox.ItemTemplate>
                                                                </ComboBox>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="🗑️" Width="Auto">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Button Content="✕"
                                                                        Command="{Binding DataContext.RemoveAltMouseBindingCommand, ElementName=RootWindow}"
                                                                        CommandParameter="{Binding}"
                                                                        Width="30"
                                                                        Height="24"
                                                                        Padding="0"
                                                                        FontSize="14"
                                                                        ToolTip="Remove this binding"
                                                                        ToolTipService.InitialShowDelay="0"
                                                                        ToolTipService.Placement="Right" />
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                </DataGrid.Columns>
                                            </DataGrid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0"
                                                        Content="Add Binding"
                                                        Command="{Binding DataContext.AddAltMouseBindingCommand, ElementName=RootWindow}"
                                                        Width="130"
                                                        Height="32" />
                                                <Button Grid.Column="1"
                                                        Content="Remove All Bindings"
                                                        Command="{Binding DataContext.RemoveAllAltMouseBindingsCommand, ElementName=RootWindow}"
                                                        Width="170"
                                                        Margin="16,0,0,0"
                                                        Height="32"
                                                        HorizontalAlignment="Right" />
                                            </Grid>
                                        </StackPanel>
                                    </GroupBox>
                                    <GroupBox Padding="16" Margin="0,0,0,8"
                                              IsEnabled="{Binding DataContext.AdvancedModeEnabled, ElementName=RootWindow}"
                                              Visibility="{Binding IsWindowsProfile, Converter={StaticResource VisibleIfFalse}}">
                                        <GroupBox.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <CheckBox Content="Right Click - Hold Breath"
                                                          IsChecked="{Binding RightClickHoldBreathEnabled}"
                                                          Margin="0"
                                                          VerticalAlignment="Center" />
                                                <TextBlock Style="{StaticResource InfoIconStyle}"
                                                           ToolTip="Upon right mouse button down, after a delay, press or toggle the hold breath key. Release on right mouse button up."
                                                           ToolTipService.InitialShowDelay="0"
                                                           ToolTipService.Placement="Right" />
                                                <TextBlock Style="{StaticResource WarningIconStyle}"
                                                           ToolTip="⚠️ WARNING: This violates '1 key = 1 action' rules in competitive or anti-cheat restricted games. Use at your own risk."
                                                           ToolTipService.InitialShowDelay="0"
                                                           ToolTipService.Placement="Right" />
                                            </StackPanel>
                                        </GroupBox.Header>
                                        <StackPanel Margin="0,8,0,0"
                                                    IsEnabled="{Binding RightClickHoldBreathEnabled}"
                                                    Tag="{Binding RightClickHoldBreathEnabled}"
                                                    Style="{StaticResource FeatureToggleContentStyle}">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="Hold breath key"
                                                           VerticalAlignment="Center"
                                                           Width="140" />
                                                <ComboBox ItemsSource="{Binding DataContext.KeyOptions, ElementName=RootWindow}"
                                                          SelectedItem="{Binding RightClickHoldBreathKey, Mode=TwoWay}"
                                                          behaviors:ComboBoxKeySelectionBehavior.EnableKeySelection="True"
                                                          Width="160">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Converter={StaticResource KeyDisplayConverter}}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <StackPanel Orientation="Horizontal" Width="140">
                                                    <TextBlock Text="Early Cancel"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Style="{StaticResource InfoIconStyle}"
                                                               ToolTip="Press the selected key or button while holding right mouse to cancel hold-breath input before it worsens sway."
                                                               ToolTipService.InitialShowDelay="0"
                                                               ToolTipService.Placement="Right" />
                                                </StackPanel>
                                                <ComboBox ItemsSource="{Binding DataContext.HoldBreathPanicTriggers, ElementName=RootWindow}"
                                                          SelectedItem="{Binding RightClickHoldBreathPanicTrigger, Mode=TwoWay}"
                                                          Width="160">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Converter={StaticResource InputTriggerDisplayConverter}}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="Suppress Early Cancel"
                                                           VerticalAlignment="Center"
                                                           Width="140" />
                                                <CheckBox IsChecked="{Binding RightClickHoldBreathSuppressEarlyCancelInput, Mode=TwoWay}"
                                                          IsEnabled="{Binding RightClickHoldBreathEarlyCancelConfigured}"
                                                          VerticalAlignment="Center" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="Mode" VerticalAlignment="Center" Width="140" />
                                                <ComboBox ItemsSource="{Binding DataContext.HoldBreathModes, ElementName=RootWindow}"
                                                          SelectedItem="{Binding RightClickHoldBreathMode, Mode=TwoWay}"
                                                          Width="160" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Delay (ms)"
                                                           VerticalAlignment="Center"
                                                           Width="140" />
                                                <Slider Value="{Binding RightClickHoldBreathDelay, UpdateSourceTrigger=PropertyChanged}"
                                                        Minimum="0"
                                                        Maximum="500"
                                                        TickFrequency="5"
                                                        IsSnapToTickEnabled="True"
                                                        Width="200"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0" />
                                                <TextBlock Text="{Binding RightClickHoldBreathDelay, StringFormat='{}{0} ms'}"
                                                           VerticalAlignment="Center"
                                                           Width="50"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                        </StackPanel>
                                    </GroupBox>
                                    <GroupBox Padding="16" Margin="0,0,0,8"
                                              IsEnabled="{Binding DataContext.AdvancedModeEnabled, ElementName=RootWindow}"
                                              Visibility="{Binding IsWindowsProfile, Converter={StaticResource VisibleIfFalse}}">
                                        <GroupBox.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <CheckBox Content="Auto-Run"
                                                          IsChecked="{Binding AutoRunEnabled}"
                                                          Margin="0"
                                                          VerticalAlignment="Center" />
                                                <TextBlock Style="{StaticResource InfoIconStyle}"
                                                           ToolTip="Press the trigger combo (modifier + key) to toggle auto-run (continuous forward movement). Enable Sprint to also send a sprint key while auto-running."
                                                           ToolTipService.InitialShowDelay="0"
                                                           ToolTipService.Placement="Right" />
                                                <TextBlock Style="{StaticResource WarningIconStyle}"
                                                           ToolTip="⚠️ WARNING: Automated / continuous input violates '1 key = 1 action' rules in competitive or anti-cheat restricted games. Use at your own risk."
                                                           ToolTipService.InitialShowDelay="0"
                                                           ToolTipService.Placement="Right" />
                                            </StackPanel>
                                        </GroupBox.Header>
                                        <StackPanel Margin="0,8,0,0"
                                                    IsEnabled="{Binding AutoRunEnabled}"
                                                    Tag="{Binding AutoRunEnabled}"
                                                    Style="{StaticResource FeatureToggleContentStyle}">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="Trigger modifier"
                                                           VerticalAlignment="Center"
                                                           Width="140" />
                                                <ComboBox ItemsSource="{Binding DataContext.TriggerModifiers, ElementName=RootWindow}"
                                                          SelectedItem="{Binding AutoRunTriggerModifier, Mode=TwoWay}"
                                                          Width="160" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="Trigger key"
                                                           VerticalAlignment="Center"
                                                           Width="140" />
                                                <ComboBox ItemsSource="{Binding DataContext.KeyOptions, ElementName=RootWindow}"
                                                          SelectedItem="{Binding AutoRunTriggerKey, Mode=TwoWay}"
                                                          behaviors:ComboBoxKeySelectionBehavior.EnableKeySelection="True"
                                                          Width="160">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Converter={StaticResource KeyDisplayConverter}}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>
                                            <CheckBox Content="Sprint"
                                                      IsChecked="{Binding AutoRunSprintEnabled}"
                                                      Margin="0,0,0,8"
                                                      VerticalAlignment="Center" />
                                            <StackPanel IsEnabled="{Binding AutoRunSprintEnabled}"
                                                        Tag="{Binding AutoRunSprintEnabled}"
                                                        Style="{StaticResource FeatureToggleContentStyle}">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="Sprint key"
                                                               VerticalAlignment="Center"
                                                               Width="140" />
                                                    <ComboBox ItemsSource="{Binding DataContext.KeyOptions, ElementName=RootWindow}"
                                                              SelectedItem="{Binding AutoRunSprintKey, Mode=TwoWay}"
                                                              behaviors:ComboBoxKeySelectionBehavior.EnableKeySelection="True"
                                                              Width="160">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Converter={StaticResource KeyDisplayConverter}}" />
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="Sprint mode"
                                                               VerticalAlignment="Center"
                                                               Width="140" />
                                                    <ComboBox ItemsSource="{Binding DataContext.SprintActivationModes, ElementName=RootWindow}"
                                                              SelectedItem="{Binding AutoRunSprintMode, Mode=TwoWay}"
                                                              Width="160" />
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Send mode"
                                                           VerticalAlignment="Center"
                                                           Width="140" />
                                                <ComboBox ItemsSource="{Binding DataContext.AutoRunSendModes, ElementName=RootWindow}"
                                                          SelectedItem="{Binding AutoRunSendMode, Mode=TwoWay}"
                                                          Width="160" />
                                                <TextBlock Style="{StaticResource WarningIconStyle}"
                                                           ToolTip="⚠️ EXPERIMENTAL: Background send posts key messages to the game window (like AutoHotkey ControlSend), so it keeps moving while alt-tabbed. Works with many games (incl. GZW); a few pure raw-input / DirectInput titles ignore it — test per game. Carries anti-cheat risk."
                                                           ToolTipService.InitialShowDelay="0"
                                                           ToolTipService.Placement="Right" />
                                            </StackPanel>
                                        </StackPanel>
                                    </GroupBox>
                                    <GroupBox Padding="16" Margin="0,0,0,8"
                                              IsEnabled="{Binding DataContext.AdvancedModeEnabled, ElementName=RootWindow}"
                                              Visibility="{Binding IsWindowsProfile, Converter={StaticResource VisibleIfFalse}}">
                                        <GroupBox.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <CheckBox Content="Anti-AFK"
                                                          IsChecked="{Binding AntiAfkEnabled}"
                                                          Margin="0"
                                                          VerticalAlignment="Center" />
                                                <TextBlock Style="{StaticResource InfoIconStyle}"
                                                           ToolTip="Prevents idle / AFK kicks by sending a brief net-zero WASD tap — but ONLY after your KEYBOARD has been genuinely inactive for the set interval (mouse movement does NOT reset it). Any real keypress resets the timer, so it never fires while you're actively playing, and it only runs while this game is focused."
                                                           ToolTipService.InitialShowDelay="0"
                                                           ToolTipService.Placement="Right" />
                                            </StackPanel>
                                        </GroupBox.Header>
                                        <StackPanel Margin="0,8,0,0"
                                                    IsEnabled="{Binding AntiAfkEnabled}"
                                                    Tag="{Binding AntiAfkEnabled}"
                                                    Style="{StaticResource FeatureToggleContentStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Interval (min)"
                                                           VerticalAlignment="Center"
                                                           Width="140" />
                                                <Slider Value="{Binding AntiAfkIntervalMinutes, UpdateSourceTrigger=PropertyChanged}"
                                                        Minimum="1"
                                                        Maximum="15"
                                                        TickFrequency="1"
                                                        IsSnapToTickEnabled="True"
                                                        Width="200"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0" />
                                                <TextBlock Text="{Binding AntiAfkIntervalMinutes, StringFormat='{}{0} min'}"
                                                           VerticalAlignment="Center"
                                                           Width="50"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                            <TextBlock Text="Only fires after real KEYBOARD inactivity — any keypress resets the timer (mouse movement does not), so it never triggers while you're actively playing."
                                                       TextWrapping="Wrap"
                                                       MaxWidth="420"
                                                       HorizontalAlignment="Left"
                                                       Margin="0,10,0,0"
                                                       FontSize="11"
                                                       Opacity="0.7" />
                                        </StackPanel>
                                    </GroupBox>
                                    <GroupBox Padding="16" Margin="0,0,0,8">
                                        <GroupBox.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <CheckBox Content="Caps Lock"
                                                          IsChecked="{Binding CapsLockEnabled}"
                                                          Margin="0"
                                                          VerticalAlignment="Center" />
                                                <TextBlock Style="{StaticResource InfoIconStyle}"
                                                           ToolTip="Remap Caps Lock to another key. Choose between different modes like Toggle, Hold, or Disabled."
                                                           ToolTipService.InitialShowDelay="0"
                                                           ToolTipService.Placement="Right" />
                                            </StackPanel>
                                        </GroupBox.Header>
                                        <StackPanel Margin="0,8,0,0"
                                                    IsEnabled="{Binding CapsLockEnabled}"
                                                    Tag="{Binding CapsLockEnabled}"
                                                    Style="{StaticResource FeatureToggleContentStyle}">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="Mode" VerticalAlignment="Center" />
                                                <ComboBox ItemsSource="{Binding DataContext.CapsLockModes, ElementName=RootWindow}"
                                                          SelectedItem="{Binding CapsLockMode, Mode=TwoWay}"
                                                          Margin="8,0,0,0" Width="160" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Remap target" VerticalAlignment="Center" />
                                                <ComboBox ItemsSource="{Binding DataContext.KeyOptionsWithNone, ElementName=RootWindow}"
                                                          SelectedItem="{Binding CapsLockRemapKey, Mode=TwoWay}"
                                                          behaviors:ComboBoxKeySelectionBehavior.EnableKeySelection="True"
                                                          Margin="8,0,0,0" Width="160">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Converter={StaticResource KeyDisplayConverter}}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>
                                        </StackPanel>
                                    </GroupBox>

                                    <GroupBox Padding="16" Margin="0,0,0,8"
                                              Visibility="{Binding IsWindowsProfile, Converter={StaticResource VisibleIfTrue}}">
                                        <GroupBox.Header>
                                            <CheckBox Content="Windows Launcher"
                                                      IsChecked="{Binding WindowsLauncherEnabled}"
                                                      Margin="0"
                                                      VerticalAlignment="Center" />
                                        </GroupBox.Header>
                                        <StackPanel Margin="0,8,0,0"
                                                    IsEnabled="{Binding WindowsLauncherEnabled}"
                                                    Tag="{Binding WindowsLauncherEnabled}"
                                                    Style="{StaticResource FeatureToggleContentStyle}">
                                            <ItemsControl ItemsSource="{Binding WindowsLaunchers}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type vm:WindowsLauncherEntryViewModel}">
                                                        <DockPanel Margin="0,4,0,4">
                                                            <StackPanel Orientation="Horizontal" Width="140" DockPanel.Dock="Left" VerticalAlignment="Center">
                                                                <TextBlock Text="Win+" Foreground="{StaticResource ForegroundPrimaryBrush}" />
                                                                <TextBlock Text="{Binding Key, Converter={StaticResource KeyDisplayConverter}}" Foreground="{StaticResource ForegroundPrimaryBrush}" />
                                                            </StackPanel>
                                                            <CheckBox Content="Run as admin" IsChecked="{Binding RunAsAdministrator}" DockPanel.Dock="Right" Margin="12,0,0,0" VerticalAlignment="Center" />
                                                            <Button Content="Browse"
                                                                    Command="{Binding DataContext.BrowseLauncherTargetCommand, ElementName=RootWindow}"
                                                                    CommandParameter="{Binding}"
                                                                    DockPanel.Dock="Right"
                                                                    Margin="8,0,0,0"
                                                                    Width="100" />
                                                            <TextBox Text="{Binding Path, UpdateSourceTrigger=PropertyChanged}" />
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </GroupBox>
                                </StackPanel>

                                <GroupBox Padding="16" Margin="0,0,0,8"
                                          Visibility="{Binding IsWindowsProfile, Converter={StaticResource VisibleIfFalse}}">
                                    <GroupBox.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <!-- For Color Profile: just show text label (profile list has its own toggle) -->
                                            <TextBlock Text="Color Settings"
                                                       Visibility="{Binding IsColorProfile, Converter={StaticResource VisibleIfTrue}}"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold" />
                                            <!-- For Game Profiles: show checkbox to enable/disable color settings -->
                                            <CheckBox Content="Color Settings"
                                                      IsChecked="{Binding ColorSettings.IsEnabled}"
                                                      Visibility="{Binding IsColorProfile, Converter={StaticResource VisibleIfFalse}}"
                                                      Margin="0"
                                                      VerticalAlignment="Center" />
                                            <TextBlock Style="{StaticResource InfoIconStyle}"
                                                       ToolTip="Adjust display color settings (NVIDIA only). For game profiles, these settings apply when the game is active. Check individual monitors to enable adjustments."
                                                       ToolTipService.InitialShowDelay="0"
                                                       ToolTipService.Placement="Right" />
                                        </StackPanel>
                                    </GroupBox.Header>
                                    <!-- For Color Profile: always enabled. For Game Profiles: enabled based on master toggle -->
                                    <StackPanel Margin="0,8,0,0">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="IsEnabled" Value="True" />
                                                <Setter Property="Opacity" Value="1" />
                                                <Style.Triggers>
                                                    <!-- Only apply graying for non-Color profiles when disabled -->
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsColorProfile}" Value="False" />
                                                            <Condition Binding="{Binding ColorSettings.IsEnabled}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="IsEnabled" Value="False" />
                                                        <Setter Property="Opacity" Value="0.75" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        
                                        <!-- Primary/Secondary color presets: edit one set of sliders at a time. -->
                                        <StackPanel Margin="0,0,0,12">
                                            <CheckBox Content="Enable a secondary color preset"
                                                      IsChecked="{Binding ColorSettings.HasSecondary}"
                                                      Margin="0,0,0,6" />
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBlock Text="Edit preset"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,10,0" />
                                                <ToggleButton Style="{StaticResource PresetVariantToggleStyle}"
                                                              IsChecked="{Binding ColorSettings.IsEditingSecondary, Mode=TwoWay}"
                                                              IsEnabled="{Binding ColorSettings.CanEditSecondary}"
                                                              Width="176"
                                                              ToolTip="Choose which color preset the display controls below edit."
                                                              AutomationProperties.Name="Color preset to edit" />
                                            </StackPanel>
                                            <TextBlock Text="Primary is the default look. Secondary is an optional alternate preset."
                                                       Foreground="{StaticResource ForegroundSecondaryBrush}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <!-- No displays message -->
                                        <TextBlock Text="No displays detected."
                                                   Foreground="{StaticResource AccentBrush}"
                                                   Visibility="{Binding ColorSettings.HasDisplays, Converter={StaticResource VisibleIfFalse}}"
                                                   Margin="0,0,0,8" />
                                        
                                        <!-- Per-monitor controls -->
                                        <ItemsControl ItemsSource="{Binding ColorSettings.DisplayViewModels}"
                                                      Visibility="{Binding ColorSettings.HasDisplays, Converter={StaticResource VisibleIfTrue}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="{StaticResource BorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="4"
                                                            Padding="12"
                                                            Margin="0,0,0,12">
                                                        <StackPanel>
                                                            <!-- Monitor header with checkbox -->
                                                            <CheckBox IsChecked="{Binding IsEnabled}"
                                                                      Content="{Binding DisplayName}"
                                                                      FontWeight="SemiBold"
                                                                      Margin="0,0,0,12" />
                                                            
                                                            <!-- Sliders container - enabled when monitor checkbox is checked -->
                                                            <StackPanel IsEnabled="{Binding AreControlsEnabled}"
                                                                        Tag="{Binding AreControlsEnabled}"
                                                                        Style="{StaticResource FeatureToggleContentStyle}">
                                                                
                                                                <!-- Brightness -->
                                                                <Grid Margin="0,0,0,10">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="140" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="Brightness" VerticalAlignment="Center" />
                                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                        <Slider Value="{Binding Brightness, UpdateSourceTrigger=PropertyChanged}"
                                                                                Minimum="0"
                                                                                Maximum="100"
                                                                                TickFrequency="1"
                                                                                IsSnapToTickEnabled="True"
                                                                                Width="240"
                                                                                Margin="0,0,8,0" />
                                                                        <TextBlock Text="{Binding Brightness, StringFormat='{}{0}%'}"
                                                                                   VerticalAlignment="Center"
                                                                                   Width="60"
                                                                                   TextAlignment="Left"
                                                                                   Foreground="{StaticResource AccentBrush}"
                                                                                   FontWeight="SemiBold" />
                                                                    </StackPanel>
                                                                    <Button Grid.Column="2"
                                                                            Content="Reset"
                                                                            Command="{Binding ResetBrightnessCommand}"
                                                                            Width="70"
                                                                            HorizontalAlignment="Right" />
                                                                </Grid>

                                                                <!-- Contrast -->
                                                                <Grid Margin="0,0,0,10">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="140" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="Contrast" VerticalAlignment="Center" />
                                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                        <Slider Value="{Binding Contrast, UpdateSourceTrigger=PropertyChanged}"
                                                                                Minimum="0"
                                                                                Maximum="100"
                                                                                TickFrequency="1"
                                                                                IsSnapToTickEnabled="True"
                                                                                Width="240"
                                                                                Margin="0,0,8,0" />
                                                                        <TextBlock Text="{Binding Contrast, StringFormat='{}{0}%'}"
                                                                                   VerticalAlignment="Center"
                                                                                   Width="60"
                                                                                   TextAlignment="Left"
                                                                                   Foreground="{StaticResource AccentBrush}"
                                                                                   FontWeight="SemiBold" />
                                                                    </StackPanel>
                                                                    <Button Grid.Column="2"
                                                                            Content="Reset"
                                                                            Command="{Binding ResetContrastCommand}"
                                                                            Width="70"
                                                                            HorizontalAlignment="Right" />
                                                                </Grid>

                                                                <!-- Gamma -->
                                                                <Grid Margin="0,0,0,10">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="140" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="Gamma" VerticalAlignment="Center" />
                                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                        <Slider Value="{Binding Gamma, UpdateSourceTrigger=PropertyChanged}"
                                                                                Minimum="0.5"
                                                                                Maximum="3"
                                                                                TickFrequency="0.05"
                                                                                IsSnapToTickEnabled="True"
                                                                                Width="240"
                                                                                Margin="0,0,8,0" />
                                                                        <TextBlock Text="{Binding Gamma, StringFormat='{}{0:F2}'}"
                                                                                   VerticalAlignment="Center"
                                                                                   Width="60"
                                                                                   TextAlignment="Left"
                                                                                    Foreground="{StaticResource AccentBrush}"
                                                                                    FontWeight="SemiBold" />
                                                                    </StackPanel>
                                                                    <Button Grid.Column="2"
                                                                            Content="Reset"
                                                                            Command="{Binding ResetGammaCommand}"
                                                                            Width="70"
                                                                            HorizontalAlignment="Right" />
                                                                </Grid>

                                                                <!-- Digital Vibrance -->
                                                                <Grid Margin="0,0,0,0">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="140" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="Digital Vibrance" VerticalAlignment="Center" />
                                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                        <Slider Value="{Binding DigitalVibrance, UpdateSourceTrigger=PropertyChanged}"
                                                                                Minimum="50"
                                                                                Maximum="100"
                                                                                TickFrequency="1"
                                                                                IsSnapToTickEnabled="True"
                                                                                Width="240"
                                                                                Margin="0,0,8,0" />
                                                                        <TextBlock Text="{Binding DigitalVibrance, StringFormat='{}{0}%'}"
                                                                                   VerticalAlignment="Center"
                                                                                   Width="60"
                                                                                   TextAlignment="Left"
                                                                                   Foreground="{StaticResource AccentBrush}"
                                                                                   FontWeight="SemiBold" />
                                                                    </StackPanel>
                                                                    <Button Grid.Column="2"
                                                                            Content="Reset"
                                                                            Command="{Binding ResetDigitalVibranceCommand}"
                                                                            Width="70"
                                                                            HorizontalAlignment="Right" />
                                                                </Grid>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </StackPanel>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>

                </ContentControl>
            </ScrollViewer>
        </Border>
        </Grid>
    </Grid>
</Window>



