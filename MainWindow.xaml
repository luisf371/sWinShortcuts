<Window x:Class="sWinShortcuts.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:sWinShortcuts.ViewModels"
        xmlns:conv="clr-namespace:sWinShortcuts.Converters"
        xmlns:behaviors="clr-namespace:sWinShortcuts.Behaviors"
        Title="sWinShortcuts"
        Icon="pack://application:,,,/Icons/Icon.ico"
        Width="1100"
        Height="720"
        MinWidth="960"
        MinHeight="640"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        x:Name="RootWindow"
        Closing="Window_Closing"
        SizeChanged="Window_SizeChanged"
        LocationChanged="Window_LocationChanged">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False"
                      NonClientFrameEdges="None" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <conv:BooleanNegationConverter x:Key="NotConverter" />
        <conv:KeyDisplayConverter x:Key="KeyDisplayConverter" />
        <conv:MouseButtonDisplayConverter x:Key="MouseButtonDisplayConverter" />
        <conv:AvailableMouseButtonsConverter x:Key="AvailableMouseButtonsConverter" />
        <conv:BooleanToVisibilityConverterEx x:Key="VisibleIfTrue" />
        <conv:BooleanToVisibilityConverterEx x:Key="VisibleIfFalse" Invert="True" />
        <Style x:Key="DisabledContentShadeStyle" TargetType="FrameworkElement">
            <Setter Property="Opacity" Value="1" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="FeatureToggleContentStyle" TargetType="FrameworkElement">
            <Setter Property="Opacity" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="False">
                    <Setter Property="Opacity" Value="0.75" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <!-- Custom Title Bar -->
        <Border Grid.Row="0"
                Background="{DynamicResource BackgroundElevatedBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                x:Name="TitleBar"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <TextBlock Text="sWinShortcuts"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="12,0,0,0"
                           Foreground="{DynamicResource ForegroundPrimaryBrush}"
                           FontSize="12" />
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">
                    <Button Click="CloseButton_Click"
                            Style="{StaticResource TitleBarCloseButtonStyle}"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.ToolTip>
                            <ToolTip Content="Minimize to tray" Background="#FF1E1E1E" Foreground="White" />
                        </Button.ToolTip>
                        <TextBlock Text="&#xE8BB;" FontSize="12" FontFamily="Segoe MDL2 Assets" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="8*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="16,8,16,16"
                Padding="16"
                Background="{DynamicResource BackgroundElevatedBrush}"
                CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ListBox Grid.Row="0"
                         ItemsSource="{Binding Profiles}"
                         SelectedItem="{Binding SelectedProfile}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{DynamicResource ForegroundPrimaryBrush}">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ProfileViewModel}">
                            <StackPanel Orientation="Horizontal" Margin="4">
                                <TextBlock Text="{Binding Name}" />
                                <TextBlock Text=" (disabled)" Margin="6,0,0,0" Foreground="{StaticResource ForegroundPrimaryBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                </ListBox>

                <Grid Grid.Row="1" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Add" Command="{Binding AddProfileCommand}" Margin="0,0,6,0" />
                    <Button Grid.Column="1" Content="Remove" Command="{Binding RemoveProfileCommand}" Margin="6,0,0,0" />
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Margin="16,8,16,16"
                Padding="0"
                Background="{DynamicResource BackgroundElevatedBrush}"
                CornerRadius="12"
                ClipToBounds="True">
            <ScrollViewer Margin="0"
                          Padding="24,16,28,24"
                          Background="Transparent"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Resources>
                    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#331E2A3B" />
                    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#88E1E1E1" />
                    <Style x:Key="MinimalScrollBarButtonStyle" TargetType="RepeatButton">
                        <Setter Property="Focusable" Value="False" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="RepeatButton">
                                    <Border Background="Transparent" />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <Style x:Key="MinimalScrollBarThumbStyle" TargetType="Thumb">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Thumb">
                                    <Border x:Name="ThumbRoot"
                                            Background="{StaticResource ScrollBarThumbBrush}"
                                            CornerRadius="4" />
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ThumbRoot"
                                                    Property="Background"
                                                    Value="{DynamicResource AccentBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsDragging" Value="True">
                                            <Setter TargetName="ThumbRoot"
                                                    Property="Background"
                                                    Value="{DynamicResource AccentDarkBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <Style TargetType="ScrollBar">
                        <Setter Property="Width" Value="8" />
                        <Setter Property="Background" Value="{StaticResource ScrollBarTrackBrush}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Grid x:Name="Root"
                                          Width="{TemplateBinding Width}"
                                          Background="Transparent">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4" />
                                        <Track x:Name="PART_Track"
                                               IsDirectionReversed="True"
                                               Margin="0">
                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton Command="ScrollBar.LineUpCommand"
                                                              Style="{StaticResource MinimalScrollBarButtonStyle}" />
                                            </Track.DecreaseRepeatButton>
                                            <Track.Thumb>
                                                <Thumb Style="{StaticResource MinimalScrollBarThumbStyle}" />
                                            </Track.Thumb>
                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton Command="ScrollBar.LineDownCommand"
                                                              Style="{StaticResource MinimalScrollBarButtonStyle}" />
                                            </Track.IncreaseRepeatButton>
                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Resources>
                <ScrollViewer.Template>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" />
                            <Border Margin="{TemplateBinding Padding}">
                                <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                        CanContentScroll="{TemplateBinding CanContentScroll}"
                                                        Content="{TemplateBinding Content}"
                                                        ContentTemplate="{TemplateBinding ContentTemplate}"
                                                        ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Border>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       HorizontalAlignment="Right"
                                       Margin="0,16,1,16"
                                       Orientation="Vertical"
                                       Minimum="0"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" />
                            <ScrollBar x:Name="PART_HorizontalScrollBar"
                                       VerticalAlignment="Bottom"
                                       Margin="16,0,16,16"
                                       Orientation="Horizontal"
                                       Minimum="0"
                                       Maximum="{TemplateBinding ScrollableWidth}"
                                       ViewportSize="{TemplateBinding ViewportWidth}"
                                       Value="{TemplateBinding HorizontalOffset}"
                                       Visibility="Collapsed" />
                        </Grid>
                    </ControlTemplate>
                </ScrollViewer.Template>
                <ContentControl Content="{Binding SelectedProfile}">
                                        <ContentControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:ProfileViewModel}">
                            <StackPanel Margin="0">
                                <CheckBox Margin="0,0,0,8"
                                          IsChecked="{Binding IsEnabled}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          VerticalContentAlignment="Center"
                                          Padding="5">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Margin="0,0,0,5"
                                               VerticalAlignment="Center" />
                                </CheckBox>

                                <StackPanel IsEnabled="{Binding IsEnabled}"
                                            Style="{StaticResource DisabledContentShadeStyle}">
                                    <StackPanel Margin="0,0,0,8"
                                                Visibility="{Binding IsWindowsProfile, Converter={StaticResource VisibleIfFalse}}">
                                        <TextBlock Text="Executable" Margin="0,0,0,4" />
                                        <DockPanel>
                                            <Button Content="Browse"
                                                    Command="{Binding DataContext.BrowseExecutableCommand, ElementName=RootWindow}"
                                                    DockPanel.Dock="Right"
                                                    Margin="8,0,0,0"
                                                    Width="100" />
                                            <TextBox Text="{Binding Executable, UpdateSourceTrigger=PropertyChanged}" />
                                        </DockPanel>
                                    </StackPanel>

                                    <GroupBox Padding="16" Margin="0,0,0,8"
                                              Visibility="{Binding IsWindowsProfile, Converter={StaticResource VisibleIfFalse}}">
                                        <GroupBox.Header>
                                            <CheckBox Content="Alt + Mouse"
                                                      IsChecked="{Binding AltMouse.IsEnabled}"
                                                      Margin="0"
                                                      VerticalAlignment="Center" />
                                        </GroupBox.Header>
                                        <StackPanel Margin="0,8,0,0"
                                                    IsEnabled="{Binding AltMouse.IsEnabled}"
                                                    Tag="{Binding AltMouse.IsEnabled}"
                                                    Style="{StaticResource FeatureToggleContentStyle}">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="Hold threshold (ms)" VerticalAlignment="Center" />
                                                <TextBox Text="{Binding AltMouse.HoldThresholdMilliseconds, UpdateSourceTrigger=PropertyChanged}" Width="60" Margin="8,0,0,0" />
                                            </StackPanel>

                                            <DataGrid ItemsSource="{Binding AltMouseBindings}"
                                                      AutoGenerateColumns="False"
                                                      HeadersVisibility="Column"
                                                      CanUserAddRows="False"
                                                      CanUserReorderColumns="False"
                                                      CanUserResizeColumns="False"
                                                      CanUserDeleteRows="False"
                                                      Margin="0,0,0,8"
                                                      RowHeight="32"
                                                      BorderThickness="0">
                                                <DataGrid.Columns>
                                                    <DataGridTemplateColumn Header="Button" Width="*">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <ComboBox SelectedItem="{Binding Button, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                                    <ComboBox.ItemsSource>
                                                                        <MultiBinding Converter="{StaticResource AvailableMouseButtonsConverter}">
                                                                            <Binding Path="DataContext.SelectedProfile.AvailableMouseButtons" ElementName="RootWindow" />
                                                                            <Binding Path="Button" />
                                                                        </MultiBinding>
                                                                    </ComboBox.ItemsSource>
                                                                    <ComboBox.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock Text="{Binding Converter={StaticResource MouseButtonDisplayConverter}}" />
                                                                        </DataTemplate>
                                                                    </ComboBox.ItemTemplate>
                                                                </ComboBox>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="Tap" Width="*">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <ComboBox ItemsSource="{Binding DataContext.KeyOptionsWithNone, ElementName=RootWindow}"
                                                                          SelectedItem="{Binding TapKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          behaviors:ComboBoxKeySelectionBehavior.EnableKeySelection="True">
                                                                    <ComboBox.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock Text="{Binding Converter={StaticResource KeyDisplayConverter}}" />
                                                                        </DataTemplate>
                                                                    </ComboBox.ItemTemplate>
                                                                </ComboBox>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="Hold" Width="*">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <ComboBox ItemsSource="{Binding DataContext.KeyOptionsWithNone, ElementName=RootWindow}"
                                                                          SelectedItem="{Binding HoldKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          behaviors:ComboBoxKeySelectionBehavior.EnableKeySelection="True">
                                                                    <ComboBox.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock Text="{Binding Converter={StaticResource KeyDisplayConverter}}" />
                                                                        </DataTemplate>
                                                                    </ComboBox.ItemTemplate>
                                                                </ComboBox>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="" Width="Auto">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Button Content="✕"
                                                                        Command="{Binding DataContext.RemoveAltMouseBindingCommand, ElementName=RootWindow}"
                                                                        CommandParameter="{Binding}"
                                                                        Width="24"
                                                                        Height="24"
                                                                        Padding="0"
                                                                        FontSize="14"
                                                                        ToolTip="Remove this binding" />
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                </DataGrid.Columns>
                                            </DataGrid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0"
                                                        Content="Add Binding"
                                                        Command="{Binding DataContext.AddAltMouseBindingCommand, ElementName=RootWindow}"
                                                        Width="130"
                                                        Height="32" />
                                                <Button Grid.Column="1"
                                                        Content="Remove All Bindings"
                                                        Command="{Binding DataContext.RemoveAllAltMouseBindingsCommand, ElementName=RootWindow}"
                                                        Width="170"
                                                        Margin="16,0,0,0"
                                                        Height="32"
                                                        HorizontalAlignment="Right" />
                                            </Grid>
                                        </StackPanel>
                                    </GroupBox>

                                    <GroupBox Padding="16" Margin="0,0,0,8"
                                              Visibility="{Binding IsWindowsProfile, Converter={StaticResource VisibleIfFalse}}">
                                        <GroupBox.Header>
                                            <CheckBox Content="Right Mouse Overrides"
                                                      IsChecked="{Binding RightMouseOverrideEnabled}"
                                                      Margin="0"
                                                      VerticalAlignment="Center" />
                                        </GroupBox.Header>
                                        <StackPanel Margin="0,8,0,0"
                                                    IsEnabled="{Binding RightMouseOverrideEnabled}"
                                                    Tag="{Binding RightMouseOverrideEnabled}"
                                                    Style="{StaticResource FeatureToggleContentStyle}">
                                            <CheckBox Content="Suppress original key"
                                                      IsChecked="{Binding SuppressOriginalRightMouseKey}"
                                                      Margin="0,0,0,8" />

                                            <DataGrid ItemsSource="{Binding RightMouseOverrides}"
                                                      SelectedItem="{Binding SelectedRightMouseOverride, Mode=TwoWay}"
                                                      AutoGenerateColumns="False"
                                                      HeadersVisibility="Column"
                                                      CanUserAddRows="False"
                                                      CanUserReorderColumns="False"
                                                      CanUserResizeColumns="False"
                                                      CanUserDeleteRows="False"
                                                      Margin="0,0,0,8"
                                                      RowHeight="32"
                                                      BorderThickness="0">
                                                <DataGrid.Columns>
                                                    <DataGridTemplateColumn Header="Source" Width="*">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <ComboBox ItemsSource="{Binding DataContext.KeyOptions, ElementName=RootWindow}"
                                                                          SelectedItem="{Binding SourceKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          behaviors:ComboBoxKeySelectionBehavior.EnableKeySelection="True">
                                                                    <ComboBox.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock Text="{Binding Converter={StaticResource KeyDisplayConverter}}" />
                                                                        </DataTemplate>
                                                                    </ComboBox.ItemTemplate>
                                                                </ComboBox>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="Target" Width="*">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <ComboBox ItemsSource="{Binding DataContext.KeyOptions, ElementName=RootWindow}"
                                                                          SelectedItem="{Binding TargetKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          behaviors:ComboBoxKeySelectionBehavior.EnableKeySelection="True">
                                                                    <ComboBox.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock Text="{Binding Converter={StaticResource KeyDisplayConverter}}" />
                                                                        </DataTemplate>
                                                                    </ComboBox.ItemTemplate>
                                                                </ComboBox>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="" Width="Auto">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Button Content="✕"
                                                                        Command="{Binding DataContext.RemoveRightMouseOverrideCommand, ElementName=RootWindow}"
                                                                        CommandParameter="{Binding}"
                                                                        Width="24"
                                                                        Height="24"
                                                                        Padding="0"
                                                                        FontSize="14"
                                                                        ToolTip="Remove this mapping" />
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                </DataGrid.Columns>
                                            </DataGrid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0"
                                                        Content="Add Mapping"
                                                        Command="{Binding DataContext.AddRightMouseOverrideCommand, ElementName=RootWindow}"
                                                        Width="130"
                                                        Height="32" />
                                                <Button Grid.Column="1"
                                                        Content="Remove All Mappings"
                                                        Command="{Binding DataContext.RemoveAllRightMouseOverridesCommand, ElementName=RootWindow}"
                                                        Width="170"
                                                        Margin="16,0,0,0"
                                                        Height="32"
                                                        HorizontalAlignment="Right" />
                                            </Grid>
                                        </StackPanel>
                                    </GroupBox>

                                    <GroupBox Padding="16" Margin="0,0,0,8">
                                        <GroupBox.Header>
                                            <CheckBox Content="Caps Lock"
                                                      IsChecked="{Binding CapsLockEnabled}"
                                                      Margin="0"
                                                      VerticalAlignment="Center" />
                                        </GroupBox.Header>
                                        <StackPanel Margin="0,8,0,0"
                                                    IsEnabled="{Binding CapsLockEnabled}"
                                                    Tag="{Binding CapsLockEnabled}"
                                                    Style="{StaticResource FeatureToggleContentStyle}">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="Mode" VerticalAlignment="Center" />
                                                <ComboBox ItemsSource="{Binding DataContext.CapsLockModes, ElementName=RootWindow}"
                                                          SelectedItem="{Binding CapsLockMode, Mode=TwoWay}"
                                                          Margin="8,0,0,0" Width="160" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Remap target" VerticalAlignment="Center" />
                                                <ComboBox ItemsSource="{Binding DataContext.KeyOptionsWithNone, ElementName=RootWindow}"
                                                          SelectedItem="{Binding CapsLockRemapKey, Mode=TwoWay}"
                                                          behaviors:ComboBoxKeySelectionBehavior.EnableKeySelection="True"
                                                          Margin="8,0,0,0" Width="160">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Converter={StaticResource KeyDisplayConverter}}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>
                                        </StackPanel>
                                    </GroupBox>

                                    <GroupBox Padding="16" Margin="0,0,0,8"
                                              Visibility="{Binding IsWindowsProfile, Converter={StaticResource VisibleIfTrue}}">
                                        <GroupBox.Header>
                                            <CheckBox Content="Windows Launcher"
                                                      IsChecked="{Binding WindowsLauncherEnabled}"
                                                      Margin="0"
                                                      VerticalAlignment="Center" />
                                        </GroupBox.Header>
                                        <StackPanel Margin="0,8,0,0"
                                                    IsEnabled="{Binding WindowsLauncherEnabled}"
                                                    Tag="{Binding WindowsLauncherEnabled}"
                                                    Style="{StaticResource FeatureToggleContentStyle}">
                                            <ItemsControl ItemsSource="{Binding WindowsLaunchers}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type vm:WindowsLauncherEntryViewModel}">
                                                        <DockPanel Margin="0,4,0,4">
                                                            <StackPanel Orientation="Horizontal" Width="140" DockPanel.Dock="Left" VerticalAlignment="Center">
                                                                <TextBlock Text="Win+" Foreground="{StaticResource ForegroundPrimaryBrush}" />
                                                                <TextBlock Text="{Binding Key, Converter={StaticResource KeyDisplayConverter}}" Foreground="{StaticResource ForegroundPrimaryBrush}" />
                                                            </StackPanel>
                                                            <CheckBox Content="Run as admin" IsChecked="{Binding RunAsAdministrator}" DockPanel.Dock="Right" Margin="12,0,0,0" VerticalAlignment="Center" />
                                                            <Button Content="Browse"
                                                                    Command="{Binding DataContext.BrowseLauncherTargetCommand, ElementName=RootWindow}"
                                                                    CommandParameter="{Binding}"
                                                                    DockPanel.Dock="Right"
                                                                    Margin="8,0,0,0"
                                                                    Width="100" />
                                                            <TextBox Text="{Binding Path, UpdateSourceTrigger=PropertyChanged}" />
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </GroupBox>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>

                </ContentControl>
            </ScrollViewer>
        </Border>
        </Grid>
    </Grid>
</Window>



