<Window x:Class="sWinShortcuts.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:sWinShortcuts.ViewModels"
        xmlns:conv="clr-namespace:sWinShortcuts.Converters"
        xmlns:behaviors="clr-namespace:sWinShortcuts.Behaviors"
        Title="sWinShortcuts"
        Icon="pack://application:,,,/Icons/Icon.ico"
        Width="1100"
        Height="720"
        MinWidth="960"
        MinHeight="640"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        x:Name="RootWindow"
        Closing="Window_Closing"
        SizeChanged="Window_SizeChanged"
        LocationChanged="Window_LocationChanged">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False"
                      NonClientFrameEdges="None" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <conv:BooleanNegationConverter x:Key="NotConverter" />
        <conv:KeyDisplayConverter x:Key="KeyDisplayConverter" />
        <conv:BooleanToVisibilityConverterEx x:Key="VisibleIfTrue" />
        <conv:BooleanToVisibilityConverterEx x:Key="VisibleIfFalse" Invert="True" />
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <!-- Custom Title Bar -->
        <Border Grid.Row="0"
                Background="{DynamicResource BackgroundElevatedBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                x:Name="TitleBar"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <TextBlock Text="sWinShortcuts"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="12,0,0,0"
                           Foreground="{DynamicResource ForegroundPrimaryBrush}"
                           FontSize="12" />
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">
                    <Button Click="CloseButton_Click"
                            Style="{StaticResource TitleBarCloseButtonStyle}"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.ToolTip>
                            <ToolTip Content="Minimize to tray" Background="#FF1E1E1E" Foreground="White" />
                        </Button.ToolTip>
                        <TextBlock Text="&#xE8BB;" FontSize="12" FontFamily="Segoe MDL2 Assets" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="8*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="16,8,16,16"
                Padding="16"
                Background="{DynamicResource BackgroundElevatedBrush}"
                CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ListBox Grid.Row="0"
                         ItemsSource="{Binding Profiles}"
                         SelectedItem="{Binding SelectedProfile}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{DynamicResource ForegroundPrimaryBrush}">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ProfileViewModel}">
                            <StackPanel Orientation="Horizontal" Margin="4">
                                <TextBlock Text="{Binding Name}" />
                                <TextBlock Text=" (disabled)" Margin="6,0,0,0" Foreground="{StaticResource ForegroundSecondaryBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Grid Grid.Row="1" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Add" Command="{Binding AddProfileCommand}" Margin="0,0,6,0" />
                    <Button Grid.Column="1" Content="Remove" Command="{Binding RemoveProfileCommand}" Margin="6,0,0,0" />
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Margin="16,8,16,16"
                Padding="0"
                Background="{DynamicResource BackgroundElevatedBrush}"
                CornerRadius="12">
            <ScrollViewer Margin="0" Padding="24,16,24,24" Background="{StaticResource BackgroundElevatedBrush}">
                <ContentControl Content="{Binding SelectedProfile}">
                                        <ContentControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:ProfileViewModel}">
                            <StackPanel Margin="0">
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="{Binding Name}"
                                              FontSize="20"
                                              FontWeight="Bold"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left" />
                                    <CheckBox Content="Enabled"
                                             IsChecked="{Binding IsEnabled}"
                                             HorizontalAlignment="Right"
                                             VerticalAlignment="Center" />
                                </Grid>

                                <StackPanel Margin="0,0,0,8"
                                            Visibility="{Binding IsWindowsProfile, Converter={StaticResource VisibleIfFalse}}">
                                    <TextBlock Text="Executable" Margin="0,0,0,4" />
                                    <DockPanel>
                                        <Button Content="Browse"
                                                Command="{Binding DataContext.BrowseExecutableCommand, ElementName=RootWindow}"
                                                DockPanel.Dock="Right"
                                                Margin="8,0,0,0" />
                                        <TextBox Text="{Binding Executable, UpdateSourceTrigger=PropertyChanged}" />
                                    </DockPanel>
                                </StackPanel>

                                <GroupBox Header="Alt + Mouse" Padding="16" Margin="0,0,0,8"
                                          Visibility="{Binding IsWindowsProfile, Converter={StaticResource VisibleIfFalse}}">
                                    <StackPanel>
                                        <CheckBox Content="Enable Alt modifiers" IsChecked="{Binding AltMouse.IsEnabled}" />
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <TextBlock Text="Hold threshold (ms)" VerticalAlignment="Center" />
                                            <TextBox Text="{Binding AltMouse.HoldThresholdMilliseconds, UpdateSourceTrigger=PropertyChanged}" Width="60" Margin="8,0,0,0" />
                                        </StackPanel>
                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Button" FontWeight="Bold" />
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Tap" FontWeight="Bold" />
                                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Hold" FontWeight="Bold" />

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Left" VerticalAlignment="Center" />
                                            <ComboBox Grid.Row="1" Grid.Column="1"
                                                      ItemsSource="{Binding DataContext.KeyOptionsWithNone, ElementName=RootWindow}"
                                                      SelectedItem="{Binding AltMouse.LeftButton.TapKey, Mode=TwoWay}"
                                                      behaviors:ComboBoxKeySelectionBehavior.EnableKeySelection="True"
                                                      Margin="4,2">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource KeyDisplayConverter}}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <ComboBox Grid.Row="1" Grid.Column="2"
                                                      ItemsSource="{Binding DataContext.KeyOptionsWithNone, ElementName=RootWindow}"
                                                      SelectedItem="{Binding AltMouse.LeftButton.HoldKey, Mode=TwoWay}"
                                                      behaviors:ComboBoxKeySelectionBehavior.EnableKeySelection="True"
                                                      Margin="4,2">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource KeyDisplayConverter}}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Right" VerticalAlignment="Center" />
                                            <ComboBox Grid.Row="2" Grid.Column="1"
                                                      ItemsSource="{Binding DataContext.KeyOptionsWithNone, ElementName=RootWindow}"
                                                      SelectedItem="{Binding AltMouse.RightButton.TapKey, Mode=TwoWay}"
                                                      behaviors:ComboBoxKeySelectionBehavior.EnableKeySelection="True"
                                                      Margin="4,2">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource KeyDisplayConverter}}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <ComboBox Grid.Row="2" Grid.Column="2"
                                                      ItemsSource="{Binding DataContext.KeyOptionsWithNone, ElementName=RootWindow}"
                                                      SelectedItem="{Binding AltMouse.RightButton.HoldKey, Mode=TwoWay}"
                                                      behaviors:ComboBoxKeySelectionBehavior.EnableKeySelection="True"
                                                      Margin="4,2">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource KeyDisplayConverter}}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>

                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Middle" VerticalAlignment="Center" />
                                            <ComboBox Grid.Row="3" Grid.Column="1"
                                                      ItemsSource="{Binding DataContext.KeyOptionsWithNone, ElementName=RootWindow}"
                                                      SelectedItem="{Binding AltMouse.MiddleButton.TapKey, Mode=TwoWay}"
                                                      behaviors:ComboBoxKeySelectionBehavior.EnableKeySelection="True"
                                                      Margin="4,2">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource KeyDisplayConverter}}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <ComboBox Grid.Row="3" Grid.Column="2"
                                                      ItemsSource="{Binding DataContext.KeyOptionsWithNone, ElementName=RootWindow}"
                                                      SelectedItem="{Binding AltMouse.MiddleButton.HoldKey, Mode=TwoWay}"
                                                      behaviors:ComboBoxKeySelectionBehavior.EnableKeySelection="True"
                                                      Margin="4,2">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource KeyDisplayConverter}}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </Grid>
                                    </StackPanel>
                                </GroupBox>

                                <GroupBox Header="Right Mouse Overrides" Padding="16" Margin="0,0,0,8"
                                          Visibility="{Binding IsWindowsProfile, Converter={StaticResource VisibleIfFalse}}">
                                    <StackPanel>
                                        <CheckBox Content="Enable right mouse overrides"
                                                  IsChecked="{Binding RightMouseOverrideEnabled}" />
                                        <CheckBox Content="Suppress original key" IsChecked="{Binding SuppressOriginalRightMouseKey}" Margin="0,8,0,8" />

                                        <DataGrid ItemsSource="{Binding RightMouseOverrides}"
                                                  SelectedItem="{Binding SelectedRightMouseOverride, Mode=TwoWay}"
                                                  AutoGenerateColumns="False"
                                                  HeadersVisibility="Column"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  Margin="0,0,0,8"
                                                  RowHeight="32"
                                                  BorderThickness="0">
                                            <DataGrid.Columns>
                                                <DataGridTemplateColumn Header="Source" Width="*">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <ComboBox ItemsSource="{Binding DataContext.KeyOptions, ElementName=RootWindow}"
                                                                      SelectedItem="{Binding SourceKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      behaviors:ComboBoxKeySelectionBehavior.EnableKeySelection="True">
                                                                <ComboBox.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock Text="{Binding Converter={StaticResource KeyDisplayConverter}}" />
                                                                    </DataTemplate>
                                                                </ComboBox.ItemTemplate>
                                                            </ComboBox>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="Target" Width="*">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <ComboBox ItemsSource="{Binding DataContext.KeyOptions, ElementName=RootWindow}"
                                                                      SelectedItem="{Binding TargetKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      behaviors:ComboBoxKeySelectionBehavior.EnableKeySelection="True">
                                                                <ComboBox.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock Text="{Binding Converter={StaticResource KeyDisplayConverter}}" />
                                                                    </DataTemplate>
                                                                </ComboBox.ItemTemplate>
                                                            </ComboBox>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="" Width="Auto">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Button Content="✕"
                                                                    Command="{Binding DataContext.RemoveRightMouseOverrideCommand, ElementName=RootWindow}"
                                                                    CommandParameter="{Binding}"
                                                                    Width="24"
                                                                    Height="24"
                                                                    Padding="0"
                                                                    FontSize="14"
                                                                    ToolTip="Remove this mapping" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                            <Button Content="Add Mapping" Command="{Binding DataContext.AddRightMouseOverrideCommand, ElementName=RootWindow}" Width="130" />
                                            <Button Content="Remove All Mappings" Command="{Binding DataContext.RemoveAllRightMouseOverridesCommand, ElementName=RootWindow}" Width="170" Margin="8,0,0,0" />
                                        </StackPanel>
                                    </StackPanel>
                                </GroupBox>

                                <GroupBox Header="Caps Lock" Padding="16" Margin="0,0,0,8">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="Mode" VerticalAlignment="Center" />
                                            <ComboBox ItemsSource="{Binding DataContext.CapsLockModes, ElementName=RootWindow}"
                                                      SelectedItem="{Binding CapsLockMode, Mode=TwoWay}"
                                                      Margin="8,0,0,0" Width="160" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Remap target" VerticalAlignment="Center" />
                                            <ComboBox ItemsSource="{Binding DataContext.KeyOptionsWithNone, ElementName=RootWindow}"
                                                      SelectedItem="{Binding CapsLockRemapKey, Mode=TwoWay}"
                                                      behaviors:ComboBoxKeySelectionBehavior.EnableKeySelection="True"
                                                      Margin="8,0,0,0" Width="160">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource KeyDisplayConverter}}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                    </StackPanel>
                                </GroupBox>

                                <GroupBox Header="Windows Launcher" Padding="16" Margin="0,0,0,8"
                                          Visibility="{Binding IsWindowsProfile, Converter={StaticResource VisibleIfTrue}}">
                                    <StackPanel>
                                        <ItemsControl ItemsSource="{Binding WindowsLaunchers}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:WindowsLauncherEntryViewModel}">
                                                    <DockPanel Margin="0,4,0,4">
                                                        <StackPanel Orientation="Horizontal" Width="140" DockPanel.Dock="Left" VerticalAlignment="Center">
                                                            <TextBlock Text="Win+" Foreground="{StaticResource ForegroundPrimaryBrush}" />
                                                            <TextBlock Text="{Binding Key, Converter={StaticResource KeyDisplayConverter}}" Foreground="{StaticResource ForegroundPrimaryBrush}" />
                                                        </StackPanel>
                                                        <CheckBox Content="Run as admin" IsChecked="{Binding RunAsAdministrator}" DockPanel.Dock="Right" Margin="12,0,0,0" VerticalAlignment="Center" />
                                                        <Button Content="Browse"
                                                                Command="{Binding DataContext.BrowseLauncherTargetCommand, ElementName=RootWindow}"
                                                                CommandParameter="{Binding}"
                                                                DockPanel.Dock="Right"
                                                                Margin="8,0,0,0" Width="80" />
                                                        <TextBox Text="{Binding Path, UpdateSourceTrigger=PropertyChanged}" />
                                                    </DockPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </GroupBox>

                            </StackPanel>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </ScrollViewer>
        </Border>
        </Grid>
    </Grid>
</Window>



